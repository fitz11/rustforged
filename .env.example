# Template for local macOS notarization credentials. Copy to `.env` and fill in.
#
#   cp .env.example .env
#
# `.env` is gitignored; this template is committed for documentation. The build
# script (scripts/build-macos.sh) sources `.env` automatically when present.
#
# IMPORTANT: The code-signing IDENTITY is configured in Cargo.toml under
# [package.metadata.packager.macos] (signing-identity), NOT here — cargo-packager
# does not read an identity env var. This file only carries the notarization key.
#
# Prerequisites:
#   - A "Developer ID Application" certificate installed in your login keychain
#     (check: security find-identity -v -p codesigning) matching the signing-identity
#     in Cargo.toml.
#   - An App Store Connect API key (.p8) for notarization; store it under .secrets/.
# See packaging/README.md for how to obtain both.

# App Store Connect API key (notarization). Omit all three to sign without notarizing.
APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"   # Issuer ID (UUID)
APPLE_API_KEY="XXXXXXXXXX"                                 # Key ID
APPLE_API_KEY_PATH=".secrets/AuthKey_XXXXXXXXXX.p8"        # path to the .p8 (relative to repo root is fine)
